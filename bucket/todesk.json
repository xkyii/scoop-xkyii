    "url": "https://dl.todesk.com/irrigation/ToDesk_4.9.7.3.exe#/dl.7z",
    "hash": "c91f0c166c2743576fca0e4ba0b2aec1988261490752c332d9eb3d0582c312b4",
    "pre_install": [
        "if (!(Test-Path \"$persist_dir\\config.ini\")) {",
        "    New-Item -Force -Path \"$persist_dir\\config.ini\" -ItemType File -Value \"[ConfigInfo]`nautoStart=0\" | Out-Null",
        "}",
        "if (Get-Command Expand-7zipArchive -ErrorAction SilentlyContinue) {",
        "    Expand-7zipArchive \"$dir\\app64.7z\" \"$dir\"",
        "} else {",
        "    7z x \"$dir\\app64.7z\" -o\"$dir\" -y",
        "}"
    ],
    "post_install": "Remove-Item \"$dir\\app64.7z\",\"$dir\\app32.7z\",\"$dir\\`$PLUGINSDIR\",\"$dir\\uninst.exe\" -Force -Recurse",
    "shortcuts": [
        [
            "ToDesk.exe",
            "ToDesk"
        ]
    ],
    "persist": [
        "Logs",
        "config.ini"
    ],
    "checkver": {
        "url": "https://update.todesk.com/windows/uplog.html",
        "regex": ">([\\d.]+)</div>"
    },
    "autoupdate": {
        "url": "https://dl.todesk.com/irrigation/ToDesk_$version.exe#/dl.7z"
    }
}