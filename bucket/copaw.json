{
    "version": "1.0.1",
    "description": "Personal AI assistant desktop app with channels, skills, workspaces and local/cloud deployment",
    "homepage": "https://github.com/agentscope-ai/CoPaw",
    "license": "GPL-3.0-only",
    "notes": [
        "CoPaw 是一个个人 AI 助手桌面应用，支持频道接入、技能、工作区以及本地/云部署",
        "上游桌面版为 Beta，但提供官方 Windows NSIS 安装器，适合由 Scoop 接管",
        "用户数据目录 1：%USERPROFILE%\\.copaw\\",
        "  - config.json：主配置",
        "  - workspaces\\：Agent 工作区",
        "  - memory\\、jobs.json、chats.json、media\\、models\\ 等运行数据",
        "用户数据目录 2：%USERPROFILE%\\.copaw.secret\\",
        "  - auth.json 等敏感认证数据",
        "安装目录 %LOCALAPPDATA%\\CoPaw 仅是程序文件位置，不属于个人数据，不纳入 Scoop persist",
        "本包会将上述两个用户数据目录持久化到 Scoop 的 persist，并在原路径创建 Junction"
    ],
    "url": "https://github.com/agentscope-ai/CoPaw/releases/download/v1.0.1/CoPaw-Setup-1.0.1.exe#/dl.7z",
    "hash": "4577bc965f371ebe0b14677ac56ab3dcc4e7cd63dc70f8f080c265117b0e74ed",
    "pre_install": "Remove-Item \"$dir\\`$*\" -Force -Recurse -ErrorAction SilentlyContinue",
    "bin": [
        [
            "copaw.cmd",
            "copaw"
        ]
    ],
    "shortcuts": [
        [
            "CoPaw Desktop.vbs",
            "CoPaw Desktop"
        ]
    ],
    "post_install": [
        "$createJunction = {",
        "    param($source, $name)",
        "    $target = Join-Path $persist_dir $name",
        "    ensure $target",
        "",
        "    if (Test-Path $source) {",
        "        $item = Get-Item -LiteralPath $source -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Write-Host \"检测到已存在的联接点：$source，跳过创建\"",
        "            return",
        "        }",
        "        if (-not $item.PSIsContainer) {",
        "            throw \"配置路径已存在且不是目录：$source\"",
        "        }",
        "",
        "        & robocopy $source $target /E /R:1 /W:1 /NFL /NDL /NJH /NJS /NP | Out-Null",
        "        if ($LASTEXITCODE -gt 7) {",
        "            Write-Host \"迁移失败，保留原目录：$source\"",
        "            return",
        "        }",
        "",
        "        $backup = \"$source.backup-$(Get-Date -Format 'yyyyMMdd-HHmmss')\"",
        "        try {",
        "            Move-Item -LiteralPath $source -Destination $backup -Force",
        "            Write-Host \"已备份原配置目录：$backup\"",
        "        } catch {",
        "            Write-Host \"无法重命名原目录：$source\"",
        "            return",
        "        }",
        "    }",
        "",
        "    New-Item -Path $source -ItemType Junction -Value $target | Out-Null",
        "}",
        "",
        "& $createJunction (Join-Path $env:USERPROFILE '.copaw') 'copaw-data'",
        "& $createJunction (Join-Path $env:USERPROFILE '.copaw.secret') 'copaw-secret'"
    ],
    "post_uninstall": [
        "$cleanup = {",
        "    param($path)",
        "    if (Test-Path $path) {",
        "        $item = Get-Item -LiteralPath $path -Force",
        "        if ($item.Attributes -band [IO.FileAttributes]::ReparsePoint) {",
        "            Remove-Item -LiteralPath $path -Force",
        "        }",
        "    }",
        "}",
        "& $cleanup (Join-Path $env:USERPROFILE '.copaw')",
        "& $cleanup (Join-Path $env:USERPROFILE '.copaw.secret')"
    ],
    "persist": [
        "copaw-data",
        "copaw-secret"
    ],
    "checkver": {
        "github": "https://github.com/agentscope-ai/CoPaw"
    },
    "autoupdate": {
        "url": "https://github.com/agentscope-ai/CoPaw/releases/download/v$version/CoPaw-Setup-$version.exe#/dl.7z",
        "hash": {
            "mode": "download"
        }
    }
}
