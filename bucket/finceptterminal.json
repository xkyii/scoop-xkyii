{
    "version": "4.0.1",
    "description": "Professional financial intelligence terminal with AI analytics",
    "homepage": "https://github.com/Fincept-Corporation/FinceptTerminal",
    "license": "AGPL-3.0-only",
    "architecture": {
        "64bit": {
            "url": "https://github.com/Fincept-Corporation/FinceptTerminal/releases/download/v4.0.1/FinceptTerminal-4.0.1-win64-setup.exe#/installer.exe",
            "hash": "ff43408a839d16b5ee3eaa2afece27fa42ea62d73f1c097dee679e0ad6d20376"
        }
    },
    "pre_install": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "New-PersistDirectory \"$env:LOCALAPPDATA\\com.fincept.terminal\" \"$persist_dir\\LOCALAPPDATA\\com.fincept.terminal\" -Migrate"
    ],
    "installer": {
        "file": "installer.exe",
        "args": [
            "install",
            "com.fincept.terminal.core",
            "com.fincept.terminal.scripts",
            "--no-default-installations",
            "--root",
            "$dir",
            "--accept-licenses",
            "--accept-messages",
            "--confirm-command"
        ]
    },
    "post_install": [
        "Remove-Item \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Fincept\\Fincept Terminal.lnk\" -Force -ErrorAction SilentlyContinue",
        "Remove-Item \"$env:USERPROFILE\\Desktop\\Fincept Terminal.lnk\" -Force -ErrorAction SilentlyContinue",
        "Remove-Item \"$env:APPDATA\\Microsoft\\Windows\\Start Menu\\Programs\\Fincept\" -Force -ErrorAction SilentlyContinue"
    ],
    "bin": "FinceptTerminal.exe",
    "shortcuts": [
        [
            "FinceptTerminal.exe",
            "Fincept Terminal"
        ]
    ],
    "pre_uninstall": [
        ". \"$bucketsdir\\$bucket\\bin\\utils.ps1\"",
        "Remove-Junction \"$env:LOCALAPPDATA\\com.fincept.terminal\""
    ],
    "uninstaller": {
        "file": "FinceptMaintenanceTool.exe",
        "args": [
            "purge",
            "--confirm-command",
            "--accept-messages"
        ]
    },
    "checkver": {
        "url": "https://api.github.com/repos/Fincept-Corporation/FinceptTerminal/releases/latest",
        "regex": "/releases/tag/v([\\w.-]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/Fincept-Corporation/FinceptTerminal/releases/download/v$version/FinceptTerminal-$version-win64-setup.exe#/installer.exe"
            }
        }
    }
}